# ─── Adama Transport Assistant — Environment Variables ───────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit the actual .env file to source control.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (PostgreSQL + PostGIS) ──────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=postgresql://transport:transport@db:5432/transport_assistant?schema=public

# ── Routing ───────────────────────────────────────────────────────────────────
# Maximum walking distance in meters a route plan may suggest
MAX_WALKING_DISTANCE_METERS=1500
