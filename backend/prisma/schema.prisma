generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum TrafficSeverity {
  LOW
  MEDIUM
  HIGH
}

model Stop {
  id                 String   @id @map("stop_id")
  code               String?  @map("stop_code")
  name               String   @map("stop_name")
  desc               String?  @map("stop_desc")
  lat                Float    @map("stop_lat")
  lon                Float    @map("stop_lon")
  zoneId             String?  @map("zone_id")
  locationType       Int?     @map("location_type")
  parentStationId    String?  @map("parent_station")
  wheelchairBoarding Int?     @map("wheelchair_boarding")
  platformCode       String?  @map("platform_code")
  location           Unsupported("geography(Point,4326)")?
  stopTimes          StopTime[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([lat, lon])
  @@map("stops")
}

model Route {
  id        String   @id @map("route_id")
  agencyId  String?  @map("agency_id")
  shortName String?  @map("route_short_name")
  longName  String?  @map("route_long_name")
  desc      String?  @map("route_desc")
  type      Int      @map("route_type")
  url       String?  @map("route_url")
  color     String?  @map("route_color")
  textColor String?  @map("route_text_color")
  trips     Trip[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("routes")
}

model Trip {
  id                    String    @id @map("trip_id")
  routeId               String    @map("route_id")
  serviceId             String    @map("service_id")
  headsign              String?   @map("trip_headsign")
  directionId           Int?      @map("direction_id")
  blockId               String?   @map("block_id")
  shapeId               String?   @map("shape_id")
  wheelchairAccessible  Int?      @map("wheelchair_accessible")
  bikesAllowed          Int?      @map("bikes_allowed")
  route                 Route     @relation(fields: [routeId], references: [id])
  stopTimes             StopTime[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([routeId])
  @@map("trips")
}

model StopTime {
  tripId           String  @map("trip_id")
  arrivalTime      String? @map("arrival_time")
  departureTime    String? @map("departure_time")
  stopId           String  @map("stop_id")
  stopSequence     Int     @map("stop_sequence")
  stopHeadsign     String? @map("stop_headsign")
  pickupType       Int?    @map("pickup_type")
  dropOffType      Int?    @map("drop_off_type")
  shapeDistTraveled Float? @map("shape_dist_traveled")
  timepoint        Int?    @map("timepoint")
  trip             Trip    @relation(fields: [tripId], references: [id])
  stop             Stop    @relation(fields: [stopId], references: [id])

  @@id([tripId, stopSequence])
  @@index([stopId])
  @@map("stop_times")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  phone     String?
  feedback  RouteFeedback[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RouteFeedback {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @db.Uuid
  user            User?    @relation(fields: [userId], references: [id])
  rating          Int
  comment         String?
  itinerarySummary String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("route_feedback")
}

model TrafficReport {
  id          String          @id @default(uuid()) @db.Uuid
  reporterId  String?         @db.Uuid
  reporter    User?           @relation(fields: [reporterId], references: [id])
  severity    TrafficSeverity @default(MEDIUM)
  description String
  lat         Float
  lon         Float
  createdAt   DateTime        @default(now())
  expiresAt   DateTime?

  @@index([lat, lon])
  @@map("traffic_reports")
}

model TaxiStandPOI {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  areaName  String
  lat       Float
  lon       Float
  location  Unsupported("geography(Point,4326)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lat, lon])
  @@map("taxi_stands")
}

model HistoricalETA {
  id                 String   @id @default(uuid()) @db.Uuid
  routeId            String?
  route              Route?   @relation(fields: [routeId], references: [id])
  fromStopId         String?
  fromStop           Stop?    @relation("HistoricalETAFromStop", fields: [fromStopId], references: [id])
  toStopId           String?
  toStop             Stop?    @relation("HistoricalETAToStop", fields: [toStopId], references: [id])
  avgDurationSeconds Int
  sampleCount        Int      @default(1)
  recordedAt         DateTime @default(now())

  @@index([routeId])
  @@map("historical_eta")
}
